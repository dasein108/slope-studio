# Copy to .env and fill what you have. Everything is optional —
# any missing key makes that stage fall back to the free path.

# --- Video + quality images (the workhorse) ---
FAL_KEY=                      # fal.ai: Nano Banana images + i2v video (Kling/Hailuo/Seedance)

# --- Script LLM (pick one free path; else offline stub is used) ---
OPENROUTER_API_KEY=           # free :free models (~50 req/day)
GROQ_API_KEY=                 # free llama-3.1-8b-instant
# Ollama needs no key — just run `ollama serve` locally (OLLAMA_HOST optional)
OLLAMA_HOST=http://localhost:11434

# --- Optional paid upgrades (not needed for MVP) ---
OPENAI_API_KEY=               # GPT-4o-mini script + OpenAI TTS
GEMINI_API_KEY=               # Gemini 2.5 Flash script + Nano Banana via Google

# --- Publishing (optional) ---
# YouTube uses OAuth client_secret*.json in repo root, not an env key.

# TikTok cross-posting (studio marketing crosspost --to tiktok). From your TikTok dev app
# (use a SANDBOX app + add your account as a target user — no review needed). The redirect
# MUST be a localhost URL registered on the app's Login Kit "Desktop" tab.
TIKTOK_CLIENT_KEY=             # TikTok app Client key
TIKTOK_CLIENT_SECRET=         # TikTok app Client secret
TIKTOK_REDIRECT_URI=http://localhost:8721/callback   # must match the Desktop Redirect URI
# Then: python scripts/tiktok_auth.py --channel <name>   (one-time token mint)
